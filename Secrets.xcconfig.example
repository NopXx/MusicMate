// Last.fm API credentials baked into the build.
// Copy this file to `Secrets.xcconfig` and fill in real values.
// `Secrets.xcconfig` is git-ignored — never commit live keys.
//
// Get keys at https://www.last.fm/api/account/create
//
// At runtime these are read from Bundle.main.infoDictionary via
// MusicMate/Sources/Scrobbler/LastFMSecrets.swift. User-provided values
// in Settings still take precedence over the bundled defaults.

LASTFM_API_KEY =
LASTFM_API_SECRET =
